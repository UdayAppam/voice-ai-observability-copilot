# Transcript source: "mock" or "highlevel"
TRANSCRIPT_PROVIDER=mock

# OpenAI API key — get one at platform.openai.com
OPENAI_API_KEY=sk-proj-...

# Model to use: gpt-4o-mini (cheap, fast) or gpt-4o (higher quality)
OPENAI_MODEL=gpt-4o-mini

# API key used by the HL Custom JS widget (generate any random 32-char string)
API_KEY=change-me-to-a-random-secret

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# SQLite database file path
DATABASE_PATH=./data/copilot.db

# Deployed backend URL (used in widget.js)
BACKEND_URL=https://your-app.railway.app

# === HighLevel — pick ONE of the two auth flows below ===

# Flow A: Private Integration Token (single-tenant developer flow)
#   Quickest for testing. Use this when you ARE the agent owner.
#   Get from: HL Sub-Account → Settings → Private Integrations
#   Required scopes: voice-ai-dashboard.readonly, voice-ai-agents.readonly
HL_PIT_TOKEN=pit-...
HL_LOCATION_ID=
HL_API_BASE=https://services.leadconnectorhq.com
HL_API_VERSION=2023-02-21

# Flow B: Marketplace App OAuth (multi-tenant, "resides within customer account")
#   Proper Marketplace App approach. Tokens stored per-location in oauth_installations.
#   Get from: HL Marketplace Developer Portal → My Apps → <your app> → Auth
#   Redirect URI must be set in your app config: <BACKEND_URL>/api/oauth/callback
HL_CLIENT_ID=
HL_CLIENT_SECRET=
HL_REDIRECT_URI=https://your-app.example.com/api/oauth/callback
